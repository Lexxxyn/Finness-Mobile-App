{
  "rules": {
    "finnness": {
      "users": {
        "$uid": {
          ".read":  "auth != null && auth.uid === $uid",
          ".write": "auth != null && auth.uid === $uid",

          "profile": {
            ".validate": "newData.hasChildren(['email'])",
            "name":   { ".validate": "newData.isString() && newData.val().length <= 80" },
            "email":  { ".validate": "newData.isString() && newData.val().matches(/^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$/)" },
            "gender": { ".validate": "newData.isString() && newData.val().length <= 16" },
            "dob":    { ".validate": "newData.isString() && newData.val().length <= 32" },
            "height": { ".validate": "newData.isNumber() && newData.val() >= 50  && newData.val() <= 250" },
            "weight": { ".validate": "newData.isNumber() && newData.val() >= 20  && newData.val() <= 300" },
            "$other": { ".validate": false }
          },

          "workouts": {
            "$workoutId": {
              ".validate": "newData.hasChildren(['name'])",
              "name":        { ".validate": "newData.isString() && newData.val().length <= 80" },
              "duration":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 600" },
              "kcal":        { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 5000" },
              "difficulty":  { ".validate": "newData.val() === 'Beginner' || newData.val() === 'Intermediate' || newData.val() === 'Advanced'" },
              "description": { ".validate": "newData.isString() && newData.val().length <= 2000" },
              "color":       { ".validate": "newData.isString() && newData.val().length <= 16" },
              "id":          { ".validate": "newData.isString()" },
              "exercises": {
                "$idx": {
                  "id":   { ".validate": "newData.isString()" },
                  "name": { ".validate": "newData.isString() && newData.val().length <= 80" },
                  "sets": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 100" },
                  "reps": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" }
                }
              }
            }
          },

          "meals": {
            "$date": {
              ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/)",
              "$type": {
                ".validate": "$type === 'breakfast' || $type === 'lunch' || $type === 'snack' || $type === 'dinner'",
                "id":       { ".validate": "newData.isString()" },
                "date":     { ".validate": "newData.isString() && newData.val() === $date" },
                "type":     { ".validate": "newData.val() === $type" },
                "foodName": { ".validate": "newData.isString() && newData.val().length <= 120" },
                "time":     { ".validate": "newData.isString() && newData.val().length <= 16" },
                "calories": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 10000" },
                "protein":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" },
                "carbs":    { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" },
                "fat":      { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1000" },
                "notes":    { ".validate": "newData.isString() && newData.val().length <= 1000" },
                "ingredients": {
                  "$idx": { ".validate": "newData.isString() && newData.val().length <= 200" }
                }
              }
            }
          },

          "sleep": {
            "$date": {
              ".validate": "$date.matches(/^[0-9]{4}-[0-9]{2}-[0-9]{2}$/) && newData.hasChildren(['totalHours'])",
              "id":         { ".validate": "newData.isString()" },
              "date":       { ".validate": "newData.isString() && newData.val() === $date" },
              "bedtime":    { ".validate": "newData.isString() && newData.val().length <= 16" },
              "wakeup":     { ".validate": "newData.isString() && newData.val().length <= 16" },
              "totalHours": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 24" },
              "deepSleep":  { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
              "lightSleep": { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" },
              "remSleep":   { ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 1" }
            }
          }
        }
      }
    }
  }
}
